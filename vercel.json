{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "sunford-valves-quotation.vercel.app"
        }
      ],
      "destination": "/Quotation/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "sunford-valves-quotation.vercel.app"
        }
      ],
      "destination": "/Quotation/:path*"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "sunford-valves-sizing.vercel.app"
        }
      ],
      "destination": "/Sizing/index.html"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "sunford-valves-sizing.vercel.app"
        }
      ],
      "destination": "/Sizing/:path*"
    }
  ]
}
